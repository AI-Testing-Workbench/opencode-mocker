const cors = require('cors');
const bodyParser = require('body-parser');
const todosRouter = require('./routes/todos');

const app = express();
const PORT = 3001;

app.use(cors());
app.use(bodyParser.json());

app.use('/api/todos', todosRouter);

app.get('/', (req, res) => {
